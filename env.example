# --- Motion Detection Sensitivity ---
# How much a pixel must change in brightness (0-255) to be counted as motion
THRESHOLD=25
# Minimum contour area in pixels to trigger a motion event (increase to ignore small movement)
MIN_AREA=800
# Gaussian blur kernel size — higher = less sensitive to noise (must be odd number)
BLUR_SIZE=21

# --- Recording Behaviour ---
# Seconds to keep recording after motion stops
MOTION_DURATION=5
# Whether to save a photo at the start of each motion event (true/false)
SAVE_PHOTOS=true
# Whether to save an H264 video clip during each motion event (true/false)
SAVE_VIDEOS=true
# Root folder where photos/ and videos/ will be created
OUTPUT_DIR=motion_captures

# --- Camera Resolution ---
MAIN_WIDTH=1920
MAIN_HEIGHT=1080
LORES_WIDTH=640
LORES_HEIGHT=480

# --- Alerts (optional — fill in if you add email notifications) ---
# ALERT_EMAIL=your_email@example.com
# SMTP_PASSWORD=your_smtp_password_here

# --- Cloud Backup (optional — fill in if you add S3 upload) ---
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# S3_BUCKET_NAME=your_bucket_name_here